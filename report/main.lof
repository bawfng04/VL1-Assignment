\contentsline {figure}{\numberline {1}{\ignorespaces Phân hệ "Quỹ đạo": Khảo sát đồng thời quỹ đạo tại 5 góc ném khác nhau. Bảng dữ liệu tự động cập nhật các thông số thiết yếu.}}{10}{figure.caption.8}%
\contentsline {figure}{\numberline {2}{\ignorespaces Phân hệ "So sánh lực cản" (Góc ném 36°): Quỹ đạo lý tưởng (xanh liền nét) và quỹ đạo thực tế (đỏ đứt nét). Ứng dụng tự động tính toán mức độ suy giảm không gian.}}{10}{figure.caption.9}%
\contentsline {figure}{\numberline {3}{\ignorespaces Phân hệ "Năng lượng": Phân tích bảo toàn cơ năng (đường xanh lá). Tại góc ném 15°, đồ thị minh họa mức độ tiêu hao cơ năng lên đến 87\% do công của lực cản.}}{11}{figure.caption.10}%
\contentsline {figure}{\numberline {4}{\ignorespaces Đường bay của vật khi có lực cản ($h = 0{,}5$ kg/s) ở các góc 15°, 30°, 45°, 60°, 75°. Dấu $\diamond $ là đỉnh cao nhất, dấu $\blacktriangledown $ là điểm rớt xuống đất.}}{12}{figure.caption.12}%
\contentsline {figure}{\numberline {5}{\ignorespaces So sánh đường bay ở góc 45°: đường liền (xanh) -- lý tưởng; đường nét đứt (đỏ) -- có lực cản $h = 0{,}5$ kg/s.}}{14}{figure.caption.14}%
\contentsline {figure}{\numberline {6}{\ignorespaces Đồ thị thay đổi vận tốc: ngang (trái), dọc (giữa), và tốc độ tổng cộng (phải) theo thời gian.}}{15}{figure.caption.15}%
\contentsline {figure}{\numberline {7}{\ignorespaces Phân tích năng lượng khi ném ở góc 45°: động năng (đỏ), thế năng (xanh dương), cơ năng tổng (xanh lá), năng lượng mất đi (tím).}}{16}{figure.caption.16}%
\contentsline {figure}{\numberline {8}{\ignorespaces Đường bay bị "móp" lại khi tăng dần lực cản $h$ từ 0 đến 2{,}0 kg/s (ném ở góc 45°).}}{17}{figure.caption.17}%
